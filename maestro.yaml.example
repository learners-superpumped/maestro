# maestro.yaml.example
# Copy this file to maestro.yaml and customise for your deployment.
# String values may reference environment variables with $VAR_NAME syntax.

project:
  name: "my-project"
  store_path: .maestro/store/maestro.db

daemon:
  # How often the planner wakes to evaluate goals and generate tasks (ms).
  planner_interval_ms: 300000
  # How often the dispatcher wakes to pick up pending tasks and launch agents (ms).
  dispatcher_interval_ms: 10000
  # How often the reconciler checks for stuck/stalled agents (ms).
  reconcile_interval_ms: 30000

concurrency:
  # Total number of agents that may run at the same time.
  max_total_agents: 5
  # Maximum concurrent agents per individual goal.
  max_per_goal: 1

budget:
  # Hard spending ceiling across all agents in a 24-hour rolling window (USD).
  daily_limit_usd: 30.0
  # Per-task spending limit. Tasks that exceed this are aborted (USD).
  per_task_limit_usd: 5.0
  # Send an alert when daily spend reaches this percentage of daily_limit_usd.
  alert_threshold_pct: 80

agent:
  # Permission mode for agent tool access.
  #   bypass     — all tools available, no prompts (--dangerously-skip-permissions)
  #   restricted — only tools listed in agent definition (--allowedTools whitelist)
  permission_mode: bypass
  # Maximum agent turns before the task is forcefully stopped. 0 = unlimited (budget-only limit).
  # default_max_turns: 0
  # If an agent produces no output for this many ms, it is considered stalled.
  stall_timeout_ms: 300000
  # Hard wall-clock time limit for a single agent turn (ms).
  turn_timeout_ms: 3600000

# agents:
#   planner:
#     role: "Goal을 분석하여 실행 가능한 task로 분해하는 플래너"
#     instructions: .maestro/prompts/planner.md
#     max_turns: 30
#     no_worktree: true
#   reviewer:
#     role: "Task 결과를 검증하는 리뷰어"
#     instructions: .maestro/prompts/reviewer.md
#     max_turns: 20
#     no_worktree: true
#   default:
#     max_turns: 50
#   sandbox:
#     permission_mode: restricted
#     tools: [Read, Bash]
#     max_turns: 10

logging:
  # Log level: debug | info | warning | error
  level: info
  # Path to the log file.
  file: ./logs/maestro.log
