{
  "mcpServers": {
    "maestro-store": {
      "command": "python",
      "args": ["-m", "maestro.mcp_store"],
      "env": {
        "MAESTRO_DAEMON_PORT": "${MAESTRO_DAEMON_PORT}"
      }
    },
    "maestro-embedding": {
      "command": "python",
      "args": ["-m", "maestro.mcp_embedding"],
      "env": {
        "MAESTRO_DAEMON_PORT": "${MAESTRO_DAEMON_PORT}"
      }
    }
  }
}
